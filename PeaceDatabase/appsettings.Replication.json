{
  "Sharding": {
    "Enabled": true,
    "Mode": "Distributed",
    "ShardCount": 3,
    "HashAlgorithm": "MurmurHash3",
    "RequestTimeoutSeconds": 30,
    "RetryCount": 3,
    "Discovery": {
      "Type": "Static",
      "ServicePrefix": "peacedb-shard-",
      "Port": 8080,
      "RefreshIntervalSeconds": 30
    },
    "Replication": {
      "Enabled": true,
      "ReplicaCount": 2,
      "WriteQuorum": 2,
      "ReadQuorum": 1,
      "FailoverTimeoutMs": 5000,
      "HealthCheckIntervalMs": 3000,
      "MaxReplicationLagMs": 10000,
      "UnhealthyThreshold": 3,
      "SyncMode": "Quorum",
      "ReadLoadBalancing": true
    },
    "ReplicaSets": [
      {
        "ShardId": 0,
        "Primary": "http://peacedb-shard-0-primary:8080",
        "Replicas": ["http://peacedb-shard-0-replica-1:8080", "http://peacedb-shard-0-replica-2:8080"]
      },
      {
        "ShardId": 1,
        "Primary": "http://peacedb-shard-1-primary:8080",
        "Replicas": ["http://peacedb-shard-1-replica-1:8080", "http://peacedb-shard-1-replica-2:8080"]
      },
      {
        "ShardId": 2,
        "Primary": "http://peacedb-shard-2-primary:8080",
        "Replicas": ["http://peacedb-shard-2-replica-1:8080", "http://peacedb-shard-2-replica-2:8080"]
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "PeaceDatabase.Storage.Sharding.Replication": "Debug"
    }
  }
}

